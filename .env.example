# 北極星 (Project Polaris) - .env.example
# docs/20, docs/24, docs/28 に基づく統合環境変数定義

# ─── アプリ基本設定 ────────────────────────────────────────────────
APP_ENV=development
PORT=3000

# ─── データベース ──────────────────────────────────────────────────
POSTGRES_USER=polaris
POSTGRES_PASSWORD=password
POSTGRES_DB=polaris
# 接続用URL (Docker Compose 以外や、特定のスキーマを指定する場合に利用)
DATABASE_URL="postgresql://polaris:password@localhost:5432/polaris"

# ─── Redis ───────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── フロントエンド ────────────────────────────────────────────────
VITE_API_URL=http://localhost:3000

# ─── AI: ローカルLLM (Primary) ────────────────────────────────────────
# docs/28 §3-1: 通常処理は原則すべてローカルQwen3で実行する
# 起動確認: npx tsx scripts/check-local-llm.ts
LOCAL_LLM_ENDPOINT=http://localhost:11434
PRIMARY_LOCAL_MODEL=qwen3-30b-a3b-2507
# Home AI provider switch (stub|local_llm|openai_api)
# local_llm を既定とし、接続不可時はアプリ側で stub fallback します
HOME_AI_PROVIDER=local_llm
# Pine generation provider switch (local_llm|deterministic|openai_api)
# deterministic は baseline / test / emergency fallback 用です
PINE_GENERATION_PROVIDER=local_llm

# ─── AI: Fallback API (GPT-5 mini) ───────────────────────────────────
# docs/28 §3-2: APIは例外時フォールバックのみ使用
# 以下の優先条件でエスカレーションされる:
#   1. Pine Script がコンパイルエラーになったとき
#   2. 2回以上の修正ループでも直らないとき
#   3. 制約が多くローカルで整合が崩れやすいとき
#   4. 最終提出用の高精度版が必要なとき
FALLBACK_API_PROVIDER=openai
FALLBACK_API_MODEL=gpt-5-mini
FALLBACK_API_KEY=
# FALLBACK_API_ENDPOINT=https://api.openai.com/v1

# ─── AI実行ポリシー ──────────────────────────────────────────────
# ローカルLLMのリトライ上限 (これを超えるとエスカレーション判定へ)
MAX_LOCAL_RETRY_COUNT=2
AI_ENABLE_STUB_FALLBACK=false

# ─── Investment calendar manual refresh ─────────────────────────────
# Multi-provider switch. Comma-separated provider list. Example: alpha_vantage,jquants,official_market.
# This takes precedence over INVESTMENT_CALENDAR_PROVIDER. Required checks use stub/fake providers.
INVESTMENT_CALENDAR_PROVIDERS=stub
# Backward-compatible single provider switch (stub|public|alpha_vantage|jquants|official_market).
INVESTMENT_CALENDAR_PROVIDER=stub
INVESTMENT_CALENDAR_FETCH_TIMEOUT_MS=10000
# Optional public provider source template for local manual smoke only.
# INVESTMENT_CALENDAR_PUBLIC_SOURCE_URL_TEMPLATE=
# Optional Alpha Vantage provider for local manual refresh smoke only. Do not commit real keys.
# INVESTMENT_CALENDAR_ALPHA_VANTAGE_API_KEY=
# INVESTMENT_CALENDAR_ALPHA_VANTAGE_TIMEOUT_MS=10000
# Optional J-Quants V2 provider for local manual refresh smoke only. Do not commit real API keys.
# INVESTMENT_CALENDAR_JQUANTS_API_KEY=
# INVESTMENT_CALENDAR_JQUANTS_TIMEOUT_MS=10000
# Optional official market calendar provider. Leave URLs unset to use bundled curated fixture events.
# INVESTMENT_CALENDAR_OFFICIAL_MARKET_TIMEOUT_MS=10000
# INVESTMENT_CALENDAR_OFFICIAL_MARKET_FOMC_URL=
# INVESTMENT_CALENDAR_OFFICIAL_MARKET_BOJ_URL=
# INVESTMENT_CALENDAR_OFFICIAL_MARKET_US_HOLIDAY_URL=

# ─── Webhook 認証 ────────────────────────────────────────────────
# 開発用初期トークン (seed.ts にも同様の値が定義されている)
WEBHOOK_TOKEN=test-webhook-token-123

# ─── ログ設定 ────────────────────────────────────────────────────
LOG_LEVEL=info

# ─── External References 収集 ───────────────────────────────────────
# docs/6: sourceTypeごとの収集基盤
# 有効化ソース: news,disclosure,earnings（カンマ区切り）
REFERENCE_ENABLED_SOURCES=news,disclosure,earnings
# 実データ source (news): Google News RSS Search
REFERENCE_NEWS_RSS_BASE_URL=https://news.google.com/rss/search
REFERENCE_NEWS_MAX_ITEMS=5
REFERENCE_FETCH_TIMEOUT_MS=10000
# 実データ source (disclosure): TDnet daily disclosure list
REFERENCE_DISCLOSURE_TDNET_LIST_URL_TEMPLATE=https://www.release.tdnet.info/inbs/I_list_001_{date}.html
REFERENCE_DISCLOSURE_MAX_ITEMS=5
REFERENCE_DISCLOSURE_ALERT_LOOKBACK_DAYS=3
REFERENCE_DISCLOSURE_SYMBOL_LOOKBACK_DAYS=14
# 実データ source (earnings): TDnet earnings-related disclosure extraction
REFERENCE_EARNINGS_TDNET_LIST_URL_TEMPLATE=https://www.release.tdnet.info/inbs/I_list_001_{date}.html
REFERENCE_EARNINGS_MAX_ITEMS=5
REFERENCE_EARNINGS_ALERT_LOOKBACK_DAYS=7
REFERENCE_EARNINGS_SYMBOL_LOOKBACK_DAYS=30
# Current snapshot source (stooq daily CSV)
SNAPSHOT_STOOQ_DAILY_URL_TEMPLATE=https://stooq.com/q/d/l/?s={symbol}&i=d
SNAPSHOT_YAHOO_CHART_URL_TEMPLATE=https://query1.finance.yahoo.com/v8/finance/chart/{symbol}
SNAPSHOT_FETCH_TIMEOUT_MS=8000
SNAPSHOT_CACHE_TTL_MS=300000
SNAPSHOT_THRESHOLD_OPEN_BUT_STALE_DAILY=20
SNAPSHOT_THRESHOLD_FRESHNESS_INVALID_DAILY=5
SNAPSHOT_THRESHOLD_FRESHNESS_EXPIRED_DAILY=10
SNAPSHOT_THRESHOLD_CANDIDATE_UNKNOWN_DAILY=30
