# 環境設定 (.env.example)
# docs/24 §7 に基づく環境変数定義
# cp .env.example .env してから各値を埋めること

# ─── アプリ基本設定 ────────────────────────────────────────────────
APP_ENV=development
PORT=3000

# ─── データベース ──────────────────────────────────────────────────
DATABASE_URL=postgresql://polaris:polaris@localhost:5432/polaris

# ─── Redis ───────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── ローカルLLM (Primary) ────────────────────────────────────────
# docs/28 §3-1: 通常処理は原則すべてローカルQwen3で実行する
# 起動確認: npx tsx scripts/check-local-llm.ts
LOCAL_LLM_ENDPOINT=http://localhost:11434
PRIMARY_LOCAL_MODEL=qwen3-30b-a3b-2507

# ─── Fallback API (GPT-5 mini) ───────────────────────────────────
# docs/28 §3-2: APIは例外時フォールバックのみ使用
# 以下の場合に限り使用する:
#   1. Pine Script がコンパイルエラーになったとき
#   2. 2回以上の修正ループでも直らないとき
#   3. 制約が多くローカルで整合が崩れやすいとき
#   4. 最終提出用の高精度版が必要なとき
FALLBACK_API_PROVIDER=openai
FALLBACK_API_MODEL=gpt-5-mini
FALLBACK_API_KEY=
# FALLBACK_API_ENDPOINT=https://api.openai.com/v1  # デフォルト値。変更不要な場合はコメントアウトのまま

# ─── AI実行ポリシー ──────────────────────────────────────────────
# ローカルLLMのリトライ上限 (これを超えるとエスカレーション判定へ)
MAX_LOCAL_RETRY_COUNT=2

# ─── Webhook 認証 ────────────────────────────────────────────────
# WEBHOOK_TOKEN はDBで管理する (webhook_tokens テーブル)
# seed.ts で初期トークンが投入される

# ─── ログ設定 ────────────────────────────────────────────────────
LOG_LEVEL=info
