{
  "name": "project-polaris",
  "version": "1.0.0",
  "private": true,
  "description": "Stock price analysis tool 'Project-polaris'",
  "scripts": {
    "dev": "pnpm --parallel --filter \"*\" dev",
    "build": "pnpm --recursive build",
    "test": "pnpm --recursive test",
    "create:snapshot-weekly-review": "node scripts/create-snapshot-weekly-review.mjs",
    "check:snapshot-weekly-review-json": "node scripts/check-snapshot-weekly-review-json.mjs",
    "test:integration:symbol-snapshot-db": "docker compose up -d postgres && npm --prefix backend run test:integration:symbol-snapshot-db:prepare && npm --prefix backend run test:integration:symbol-snapshot-db",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "up": "docker compose up -d",
    "down": "docker compose down"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.57.0",
    "vitest": "^2.1.9"
  },
  "packageManager": "pnpm@9.0.0"
}
